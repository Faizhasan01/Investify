# Express server port (defaults to 5000)
PORT=5000

# LLM Providers API Keys (Optional if provided dynamically via the frontend settings)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Search API Key (Optional - if missing, the backend defaults to DuckDuckGo HTML scraping fallback)
TAVILY_API_KEY=your_tavily_api_key_here
